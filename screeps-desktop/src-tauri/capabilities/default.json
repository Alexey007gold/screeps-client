{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Screeps desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "http://*:*" },
        { "url": "https://*" },
        { "url": "https://*:*" }
      ]
    },
    "opener:default"
  ]
}

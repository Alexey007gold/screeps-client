{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Screeps",
  "version": "0.1.0",
  "identifier": "com.screeps.client.desktop",
  "build": {
    "frontendDist": "../../screeps-client/dist/standalone",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter screeps-client dev",
    "beforeBuildCommand": "pnpm --filter screeps-client build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Screeps",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws: wss: https: http:; img-src 'self' data: blob: https:; media-src 'self' blob:; worker-src 'self' blob:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
